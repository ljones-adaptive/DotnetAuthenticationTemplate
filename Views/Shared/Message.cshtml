@model ScalpingApp.ViewModels.MessageViewModel
@{ ViewData["Title"] = Model.Title; Layout = "_Layout"; }
<div class="page-center">
  <div style="width:100%;max-width:420px;text-align:center">
    <div class="card">
      <h2 style="font-size:1.1rem;font-weight:600;margin-bottom:1rem;color:var(--accent)">@Model.Title</h2>
      <p class="text-muted" style="font-size:0.9rem;line-height:1.6">@Model.Message</p>
      @if (Model.ShowLogin)
      {
        <a class="btn btn-primary" href="/Account/Login" style="margin-top:1.5rem;display:inline-flex">Go to Login</a>
      }
    </div>
  </div>
</div>
