@using System.Security.Claims
@{
    var username = User.Identity?.Name ?? "";
    var initial  = username.Length > 0 ? username[0].ToString().ToUpper() : "?";
    var isAdmin  = User.HasClaim("role", "Admin");
}
<div class="topbar">
  <span class="topbar-title">Scalping | Adaptive Realtime Trading</span>
  <div class="profile-menu">
    <a class="profile-btn" href="/Profile" title="Profile">@initial</a>
    <div class="profile-dropdown">
      <a href="/Profile">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.121 17.804A9 9 0 1118.88 6.196M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Profile
      </a>
      <a href="/Home">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7m-9 2v8m4-8v8m5 0H5a2 2 0 01-2-2v-6"/></svg>
        Home
      </a>
      @if (isAdmin)
      {
        <a href="/Admin/Users">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-5-3.87M9 20H4v-2a4 4 0 015-3.87m6-4a4 4 0 11-8 0 4 4 0 018 0zm6 4a2 2 0 100-4 2 2 0 000 4zM3 16a2 2 0 100-4 2 2 0 000 4z"/></svg>
          User Management
        </a>
      }
      <div class="dropdown-divider"></div>
      <a href="/Account/Logout" class="dropdown-danger">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1"/></svg>
        Logout
      </a>
    </div>
  </div>
</div>
