@model ScalpingApp.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Register"; Layout = "_Layout"; }
<div class="page-center">
  <div style="width:100%;max-width:440px">
    <div class="text-center" style="margin-bottom:2rem">
      <h1 style="font-size:1.4rem;font-weight:700;color:var(--accent)">Create Account</h1>
      <p class="text-muted" style="margin-top:0.25rem">Scalping | Adaptive Realtime Trading</p>
    </div>
    <div class="card">
      <div asp-validation-summary="All" class="validation-summary-errors"></div>
      <form method="post">
        <div class="form-group">
          <label>Username</label>
          <input asp-for="Username" type="text" required />
          <span asp-validation-for="Username" class="field-validation-error"></span>
        </div>
        <div class="form-group">
          <label>Email Address</label>
          <input asp-for="Email" type="email" required />
          <span asp-validation-for="Email" class="field-validation-error"></span>
        </div>
        <div class="form-group">
          <label>Password</label>
          <div class="pw-wrap">
            <input asp-for="Password" type="password" required />
            <button type="button" class="pw-toggle"></button>
          </div>
        </div>
        <div class="form-group">
          <label>Confirm Password</label>
          <div class="pw-wrap">
            <input asp-for="ConfirmPassword" type="password" required />
            <button type="button" class="pw-toggle"></button>
          </div>
        </div>
        <button class="btn btn-primary btn-full mt2" type="submit">Register</button>
      </form>
      <p class="text-center mt2 text-muted" style="font-size:0.875rem">
        Already have an account? <a href="/Account/Login">Log in</a>
      </p>
    </div>
  </div>
</div>
